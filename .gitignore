# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Packaging / build artifacts
build/
dist/
wheels/
*.egg
*.egg-info/
.eggs/

# The hand-built distribution archive
*.tar.gz

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/

# Editor / OS cruft
.vscode/
.idea/
*.swp
*~
.DS_Store

# Runtime state & credentials — these normally live in your XDG dirs, not the
# repo, but never commit them if they ever turn up in the working tree.
*.sock
*.log
config.json
session.json
queue.json
*token*.json
